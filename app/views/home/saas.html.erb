<%= javascript_include_tag 'hero_parallax', nonce: SecureHeaders.content_security_policy_script_nonce(request), defer: true %>

<%= javascript_tag nonce: SecureHeaders.content_security_policy_script_nonce(request), data: { cfasync: "false" } do %>
  (function() {
    function initSaasCalculator() {
      const root = document.querySelector('[data-saas-calc]');
      if (!root) return;

      const formatNumber = (n) => Number(n).toLocaleString('en-US');
      const inputs = Array.from(root.querySelectorAll('[data-saas-calc-input]')).map((input) => ({
        input,
        key: input.dataset.saasCalcInput,
        display: root.querySelector('[data-saas-calc-value="' + input.dataset.saasCalcInput + '"]'),
      }));
      const resultPanel = root.querySelector('[data-saas-calc-result-panel]');
      const revenueOutputs = root.querySelectorAll('[data-saas-calc-revenue]');
      const feeOutputs = root.querySelectorAll('[data-saas-calc-fee]');
      const keepOutputs = root.querySelectorAll('[data-saas-calc-keep]');
      const rateOutputs = root.querySelectorAll('[data-saas-calc-rate]');

      function recompute() {
        const state = {};
        inputs.forEach(({ input, key, display }) => {
          state[key] = Number(input.value);
          input.style.setProperty('--fill', ((input.value - input.min) / (input.max - input.min)) * 100 + '%');
          if (display) display.textContent = formatNumber(input.value);
        });

        const revenue = state.price * state.sales;
        const crossed = state.lifetime >= 100000;
        const rate = crossed ? 0.05 : 0.10;
        const fee = Math.round(revenue * rate);
        const keep = revenue - fee;

        revenueOutputs.forEach((el) => el.textContent = formatNumber(revenue));
        feeOutputs.forEach((el) => el.textContent = formatNumber(fee));
        keepOutputs.forEach((el) => el.textContent = formatNumber(keep));
        rateOutputs.forEach((el) => el.textContent = (rate * 100).toFixed(0));

        if (resultPanel) {
          resultPanel.classList.toggle('bg-purple', !crossed);
          resultPanel.classList.toggle('bg-yellow', crossed);
        }
      }

      inputs.forEach(({ input }) => input.addEventListener('input', recompute));
      recompute();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSaasCalculator);
    } else {
      initSaasCalculator();
    }
  })();
<% end %>
