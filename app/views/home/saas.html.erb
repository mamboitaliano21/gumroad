            </div>
            <div class="mt-1 flex items-baseline justify-between border-t border-black pt-2.5">
              <span class="text-sm font-semibold">You keep</span>
              <span class="text-base font-bold tabular-nums">$<span data-saas-calc-keep>4,410</span></span>
            </div>
          </div>
        </div>
