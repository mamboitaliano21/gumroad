      <div class="hero-coin saas-hero-token--cursor absolute" data-parallax-intensity="-0.018" data-scroll-intensity="-0.08">
        <div class="-rotate-12">
          <%= image_tag "saas/hero-cursor.png", alt: "", class: "h-auto w-full" %>
        </div>
      </div>
      <div class="hero-coin saas-hero-token--license absolute" data-parallax-intensity="0.02" data-scroll-intensity="-0.10">
        <div class="-rotate-6">
          <%= image_tag "saas/hero-license.png", alt: "", class: "h-auto w-full" %>
        </div>
      </div>
      <div class="hero-coin saas-hero-token--checkout absolute" data-parallax-intensity="-0.022" data-scroll-intensity="-0.09">
