<style>
  .gr-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 28px;
    background: transparent;
    outline: none;
    margin: 0;
    padding: 0;
    cursor: pointer;
  }
  .gr-slider::-webkit-slider-runnable-track {
    height: 12px;
    background: linear-gradient(to right, #f1f333 0%, #f1f333 var(--fill, 0%), #fff var(--fill, 0%), #fff 100%);
    border: 1px solid #000;
    border-radius: 4px;
  }
  .gr-slider::-moz-range-track {
    height: 12px;
    background: linear-gradient(to right, #f1f333 0%, #f1f333 var(--fill, 0%), #fff var(--fill, 0%), #fff 100%);
    border: 1px solid #000;
    border-radius: 4px;
  }
  .gr-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    background: var(--color-purple);
    border: 1px solid #000;
    border-radius: 4px;
    margin-top: -9px;
    box-shadow: 2px 2px 0 #000;
    transition: box-shadow 0.08s, transform 0.08s;
  }
  .gr-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    background: var(--color-purple);
    border: 1px solid #000;
    border-radius: 4px;
    box-shadow: 2px 2px 0 #000;
    transition: box-shadow 0.08s, transform 0.08s;
  }
  .gr-slider:active::-webkit-slider-thumb {
    box-shadow: none;
    transform: translate(2px, 2px);
  }
  .gr-slider:active::-moz-range-thumb {
    box-shadow: none;
    transform: translate(2px, 2px);
  }
  .saas-hero-token--cursor {
    left: clamp(4rem, 7vw, 8.5rem);
    top: clamp(3.5rem, 6vw, 6rem);
    width: clamp(4.5rem, 6vw, 6.5rem);
  }
  .saas-hero-token--license {
    left: clamp(3rem, 5vw, 7rem);
    top: clamp(17rem, 27vw, 21.5rem);
    width: clamp(5rem, 7vw, 7.75rem);
  }
  .saas-hero-token--checkout {
    right: clamp(2.5rem, 5vw, 4.5rem);
    top: clamp(2rem, 4vw, 4rem);
    width: clamp(4.75rem, 6vw, 5.75rem);
  }
  .saas-hero-token--stars {
    right: clamp(4rem, 7vw, 12rem);
    top: clamp(24rem, 32vw, 27rem);
    width: clamp(4.25rem, 5.5vw, 5.75rem);
  }
  @media (min-width: 1280px) {
    .saas-hero-token--cursor {
      width: clamp(6.5rem, 7vw, 7.5rem);
    }
    .saas-hero-token--license {
      top: clamp(17rem, 20vw, 22rem);
      width: clamp(7.5rem, 8vw, 9rem);
    }
    .saas-hero-token--checkout {
      right: clamp(3rem, 4vw, 6rem);
      top: clamp(8rem, 10vw, 10.5rem);
      width: clamp(7.5rem, 8vw, 9.75rem);
    }
  }
</style>

