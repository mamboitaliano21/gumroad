<section id="faq" class="bg-white">
  <div class="mx-auto max-w-4xl px-8 py-20 lg:px-12 lg:py-24">
    <h2 class="mb-12 text-balance text-center text-4xl font-medium leading-[1.05] sm:text-5xl md:text-6xl">Frequently asked questions</h2>

    <div class="border-t border-black">
      <% [
        ["What kinds of software can I sell?", "Anything with a download or a license key — desktop apps, plugins, scripts, fonts, game assets, code. Subscriptions and one-time purchases both work."],
        ["Do I need to write code to use this?", "No. You set up products and tiers in the Gumroad dashboard and share a checkout link. If you want to verify license keys from your app, you can call our REST API — no SDK required."],
        ["How does the license key API work?", "Every sale creates a unique license key. You hit our API to verify, disable, or rotate it — the response includes a use counter so you can enforce activation limits from your app."],
        ["What does 'merchant of record' actually mean?", "Gumroad is the seller on the invoice. We charge the buyer, collect and file VAT and sales tax in every country that requires it, handle chargebacks, and absorb fraud. You receive a net payout."],
        ["When does the rate drop to 5%?", "Once your lifetime sales on Gumroad cross $100,000, every sale after that is 5% instead of 10%."],
        ["Can I use my own domain?", "Yes. Point your own domain at Gumroad and sell from there instead of gumroad.com — your branding stays consistent through checkout."]
      ].each do |question, answer| %>
        <div class="accordion-item border-b border-black">
          <div class="flex cursor-pointer items-center gap-4 py-5" data-accordion-trigger>
            <div class="flex h-6 w-6 shrink-0 items-center justify-center">
              <svg width="24" height="24" viewBox="0 0 32 32" aria-hidden="true">
                <line x1="4" y1="16" x2="28" y2="16" stroke="black" stroke-width="2" />
                <line x1="16" y1="4" x2="16" y2="28" stroke="black" stroke-width="2" class="transition-transform duration-300" />
              </svg>
            </div>
            <h3 class="text-base font-medium md:text-lg"><%= question %></h3>
          </div>
          <div class="max-h-0 overflow-hidden transition-[max-height] duration-300" data-accordion-content>
            <div class="max-w-3xl pb-6 pl-10 text-base leading-relaxed text-dark-gray"><%= answer %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

